# crea la carpeta (si no existe)
mkdir -p img

# mover todos los tipos comunes de imágenes, excluyendo ya los que estén dentro de img/
find . -type f \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.gif' -o -iname '*.svg' \) \
  -not -path './img/*' -print0 \
  | while IFS= read -r -d '' file; do
    target="img/$(basename "$file")"
    if [ -e "$target" ]; then
      echo "CONFLICT: $target already exists. Skipping $file"
      # Aqui podrías renombrar o decidir manualmente
    else
      git mv "$file" "$target"
    fi
  done
